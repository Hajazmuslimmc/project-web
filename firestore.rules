rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // Allow read for authenticated users
      allow read: if request.auth != null;
      // Allow write only for the user themselves or admins
      allow write: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod']);
      // Allow create for authenticated users
      allow create: if request.auth != null;
    }

    // Messages collection
    match /messages/{messageId} {
      // Allow read for authenticated users
      allow read: if request.auth != null;
      // Allow write for authenticated users
      allow write: if request.auth != null;
      // Allow create for authenticated users
      allow create: if request.auth != null;
    }

    // Private chats collection
    match /privateChats/{chatId} {
      // Allow read/write if user is a participant
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      // Allow create if user is one of the participants
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
    }

    // Social posts collection
    match /socialPosts/{postId} {
      // Allow read for authenticated users
      allow read: if request.auth != null;
      // Allow write for authenticated users (they can only modify their own posts)
      allow write: if request.auth != null &&
        (request.auth.uid == resource.data.authorId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod']);
      // Allow create for authenticated users
      allow create: if request.auth != null;
    }
  }
}
